pipeline {
    agent any
    
    stages {
        stage('Install Dependencies') {
            steps {
                dir('edu_connect_pak_updated/server') {
                    bat 'npm install'
                }
            }
        }
        
        stage('Run Unit Tests') {
            steps {
                dir('edu_connect_pak_updated/server') {
                    bat 'npm run test:unit'
                }
            }
        }
        
        stage('Run Integration Tests') {
            steps {
                dir('edu_connect_pak_updated/server') {
                    bat 'npm run test:integration'
                }
            }
        }
    }
    
    post {
        success {
            echo '✅ All tests passed!'
        }
        failure {
            echo '❌ Some tests failed!'
        }
    }
}